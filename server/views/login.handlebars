<header class="header">
  <div class="container">
    <div class="search-container">
      <img alt="logo-mercado-livre" class="logo" src="https://http2.mlstatic.com/D_NQ_NP_758782-MLA78816706095_082024-F.jpg">
      <a href="/" class="search-btn" style="text-decoration:none; display:flex; align-items:center; gap:8px;">
        <i class="fa-solid fa-house"></i>
        Home
      </a>
      <a href="/cart" class="search-btn" style="text-decoration:none; display:flex; align-items:center; gap:8px;">
        <i class="fa-solid fa-cart-shopping"></i>
        Carrinho
      </a>
    </div>
  </div>
  </header>

<main class="main">
  <div class="container" style="max-width:480px;">
    <h2 class="section-title">Entrar na conta</h2>
    {{#if error}}
      <div style="color:#b00020; margin-bottom:12px;">{{error}}</div>
    {{/if}}
    <form method="post" action="/login" style="display:flex; flex-direction:column; gap:12px;">
      <input type="email" name="email" placeholder="Seu e-mail" class="search-input" required>
      <button type="submit" class="search-btn" style="align-self:flex-start;">
        <i class="fa-solid fa-right-to-bracket"></i>
        Entrar
      </button>
      <a href="/admin/customers/new" class="search-btn" style="text-decoration:none; display:flex; align-items:center; gap:8px;">
        <i class="fa-solid fa-user-plus"></i>
        Criar conta
      </a>
    </form>
  </div>
</main>

<footer class="footer">
  <p>Clone do Mercado Livre - Oficial DevClub</p>
</footer>