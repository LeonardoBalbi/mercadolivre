<header class="header">
  <div class="container">
    <div class="search-container">
      <img alt="logo-mercado-livre" class="logo" src="https://http2.mlstatic.com/D_NQ_NP_758782-MLA78816706095_082024-F.jpg">
      <a href="/" class="search-btn" style="text-decoration:none;">Home</a>
      <a href="/admin/customers/new" class="search-btn" style="text-decoration:none;">Cadastrar clientes</a>
    </div>
  </div>
</header>

<main class="main">
  <div class="container">
    <h2 class="section-title">Clientes</h2>
    <form action="/admin/customers" method="get" style="display:flex;gap:8px;margin-bottom:12px;">
      <input type="text" name="q" value="{{q}}" placeholder="Buscar por nome ou e-mail" class="search-input" style="flex:1;">
      <button type="submit" class="search-btn">Buscar</button>
    </form>
    <div style="overflow:auto;">
      <table style="width:100%; border-collapse:collapse;">
        <thead>
          <tr>
            <th style="text-align:left; padding:10px;">Nome</th>
            <th style="text-align:left; padding:10px;">E-mail</th>
            <th style="text-align:left; padding:10px;">Telefone</th>
            <th style="text-align:left; padding:10px;">Ações</th>
          </tr>
        </thead>
        <tbody>
          {{#each customers}}
            <tr style="background:#fff;">
              <td style="padding:10px;">{{this.name}}</td>
              <td style="padding:10px;">{{this.email}}</td>
              <td style="padding:10px;">{{this.phone}}</td>
              <td style="padding:10px;">
                <a href="/admin/customers/{{this.id}}/edit" class="search-btn" style="text-decoration:none;">Editar</a>
                <form action="/admin/customers/{{this.id}}/delete" method="post" style="display:inline;">
                  <button class="search-btn" onclick="return confirm('Excluir cliente?')">Excluir</button>
                </form>
              </td>
            </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{#if pages}}
      <div style="margin-top:12px; display:flex; gap:6px; flex-wrap:wrap;">
        {{#each (range 1 pages)}}
          <a href="/admin/customers?page={{this}}{{#if ../q}}&q={{../q}}{{/if}}" class="search-btn" style="text-decoration:none;">{{this}}</a>
        {{/each}}
      </div>
    {{/if}}
  </div>
</main>

<footer class="footer">
  <p>Clone do Mercado Livre - Oficial DevClub</p>
</footer>